{{ 'volume-calculator.css' | asset_url | stylesheet_tag }}

<div class="bgs-volume-calculator" id="bgs-volume-calculator">

  <h2>{{ section.settings.heading }}</h2>

  <div class="bgs-form">

    <div class="bgs-field">

      <label>
        Weight:
        <strong><span id="weightValue">80</span> kg</strong>
      </label>

      <input
        type="range"
        class="weight"
        min="35"
        max="110"
        value="80"
        step="1">

    </div>

    <div class="bgs-field">

      <label>Skill Level</label>

      <select id="skill">

        <option value="0.72">Beginner</option>
        <option value="0.54">Intermediate Beginner</option>
        <option value="0.45" selected>Intermediate</option>
        <option value="0.38">Advanced Intermediate</option>
        <option value="0.36">Advanced</option>

      </select>

    </div>

    <button
      id="calculateVolume"
      class="bgs-btn">

      Calculate Volume

    </button>

  </div>

  <div
    id="volumeResult"
    class="bgs-result">

    <h3>Recommended Volume</h3>

    <div class="bgs-volume-number">

      <span id="volumeLitres">00.0</span>L

    </div>

    <p>

      Recommended Range:

      <strong>

        <span id="volumeMin">00.0</span>L -

        <span id="volumeMax">00.0</span>L

      </strong>

    </p>

    <p
      id="volumePlaceholder"
      class="bgs-placeholder">

      {{ section.settings.placeholder }}

    </p>

    <a
      id="shopBoardsBtn"
      href="{{ section.settings.collection.url }}"
      class="bgs-shop-btn disabled">

      {{ section.settings.button_label }}

    </a>

  </div>

</div>

<script src="{{ 'volume-calculator.js' | asset_url }}" defer></script>

{% schema %}
{
  "name": "Volume Calculator",
  "tag": "section",
  "class": "section-volume-calculator",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Find Your Perfect Volume"
    },
    {
      "type": "textarea",
      "id": "placeholder",
      "label": "Placeholder",
      "default": "Adjust your weight and select your skill level, then click \"Calculate Volume\"."
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button Label",
      "default": "Shop Surfboards"
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Surfboard Collection"
    }
  ],
  "presets": [
    {
      "name": "Volume Calculator"
    }
  ]
}
{% endschema %}